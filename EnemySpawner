import java.awt.*;
import javax.swing.*;

public class EnemySpawner extends GameObject {

    private static final int SPAWN_INTERVAL_MS = 10000; // 10 секунд
    private Engine engine;

    public EnemySpawner() {
        engine = Engine.getInstance();

        // таймер спавна
        Timer spawnTimer = new Timer(SPAWN_INTERVAL_MS, e -> spawnUnit());
        spawnTimer.start();
    }

    private void spawnUnit() {
        if (engine == null) {
            engine = Engine.getInstance();
            if (engine == null) {
                System.err.println("Engine не найден!");
                return;
            }
        }

        UnitGunner unit = new UnitGunner();

        // Спавн у ПРАВОГО края экрана
        float spawnX = engine.getScreenWidth() - 50; // Отступ 50px от правого края
        float spawnY = 300; // Фиксированная Y координата, или можно рандомную

        unit.setX(spawnX);
        unit.setY(spawnY);
        unit.setEngine(engine);

        engine.spawnObject(unit);
        System.out.println("🎮 Враг заспавнен у правого края! X=" + spawnX + ", Y=" + spawnY);
    }

    @Override
    public void update(float dt) {
        // Спавнеру не нужно обновление
    }

    @Override
    public void draw(Graphics g) {
        // Спавнер ничего не рисует
    }
}
